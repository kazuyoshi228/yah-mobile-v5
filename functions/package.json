    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "nodemailer": "^6.9.16",
    "stripe": "^22.2.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
